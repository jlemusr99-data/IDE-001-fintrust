----inserta datos limpios de pago

CREATE TABLE IF NOT EXISTS PrdDatoscaso.pagos (
 payment_id STRING,
 loan_id STRING,
 installment_id STRING,
 payment_date TIMESTAMP,
 payment_amount FLOAT64,
 payment_channel STRING,
 payment_status STRING,
 loaded_at TIMESTAMP
);
INSERT INTO PrdDatoscaso.pagos (
  payment_id,
  loan_id,
  installment_id,
  payment_date,
  payment_amount,
  payment_channel,
  payment_status,
  loaded_at
)
SELECT
  payment_id,
  loan_id,
  installment_id,
  TIMESTAMP(payment_date) AS payment_date,
  payment_amount,
  payment_channel,
  payment_status,
  loaded_at
FROM DevDatoscaso.payments;
